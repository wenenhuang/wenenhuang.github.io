# .gitignore

# ====================
# 操作系统自动生成文件
# ====================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Thumbs.db:encryptable

# ====================
# 编辑器 / IDE
# ====================
.vscode/
.idea/
*.swp
*.swo
*~

# ====================
# 日志与临时文件
# ====================
*.log
tmp/
temp/
*.tmp
*.temp

# ====================
# 依赖、构建、环境文件（通用必备）
# ====================
node_modules/
dist/
build/
.env
.env.local
.env.*.local